PENTAI_ENVIRONMENT=development
PENTAI_APP_NAME=PentAI Pro API
PENTAI_ALLOWED_NETWORK=172.20.32.0/18
PENTAI_COMMAND_NODE_IP=172.20.32.74
PENTAI_WEAPON_NODE_URL=https://172.20.32.68:5000
PENTAI_POSTGRES_DSN=postgresql+psycopg://pentai:pentai@postgres:5432/pentai
PENTAI_REDIS_URL=redis://redis:6379/0
PENTAI_OLLAMA_URL=http://ollama:11434
PENTAI_GATEWAY_AUDIENCE=pentai-tool-gateway
PENTAI_GATEWAY_JWT_SECRET=replace-this-before-use
PENTAI_OPERATOR_NAME=lab-operator

# Auth (legacy cookie sessions — used as fallback)
PENTAI_AUTH_JWT_SECRET=replace-with-32-plus-bytes-random-secret
PENTAI_AUTH_JWT_TTL_SECONDS=43200

# CORS — comma-separated list of allowed frontend origins
PENTAI_CORS_ALLOW_ORIGINS=http://localhost:3000

# Frontend API URL — copy into frontend/.env.local as well
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase — get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# JWT secret — Project Settings → API → JWT Settings → JWT Secret
PENTAI_SUPABASE_JWT_SECRET=your-supabase-jwt-secret
